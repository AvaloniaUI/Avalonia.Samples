<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:QrCodeSample.ViewModels"
             xmlns:markupExtensions="clr-namespace:QrCodeSample.MarkupExtensions"
             xmlns:services="clr-namespace:QrCodeSample.Services"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             services:DialogManager.Register="{Binding}"
             x:DataType="viewModels:EncodeQrViewModel"
             x:Class="QrCodeSample.Views.QrEncoderView">
    <UserControl.DataContext>
        <viewModels:EncodeQrViewModel />
    </UserControl.DataContext>

    <Grid RowDefinitions="Auto, Auto, *"
          Margin="10"
          RowSpacing="15">
        <CommandBar CornerRadius="10"
                    DefaultLabelPosition="Right">
            <CommandBar.Content>
                <TextBlock Text="Encode QR Code"
                           Classes="h1" />
            </CommandBar.Content>
            <CommandBar.PrimaryCommands>
                <!-- Copy result to Clipboard -->
                <CommandBarButton Label="Copy"
                                  Command="{Binding CopyCommand}">
                    <CommandBarButton.Icon>
                        <PathIcon Data="{DynamicResource CopyIcon}" />
                    </CommandBarButton.Icon>
                </CommandBarButton>

                <CommandBarButton Label="Save"
                                  Command="{Binding SaveCommand}">
                    <CommandBarButton.Icon>
                        <PathIcon Data="{DynamicResource SaveIcon}" />
                    </CommandBarButton.Icon>
                </CommandBarButton>

            </CommandBar.PrimaryCommands>
        </CommandBar>

        <GroupBox Grid.Row="1"
                  Header="Input Data">
            <Grid ColumnDefinitions="Auto, *"
                  RowDefinitions="Auto, Auto, Auto"
                  ColumnSpacing="10"
                  RowSpacing="10">
                <TextBlock Text="Text to encode:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding TextToEncode}" />
                
                <TextBlock Grid.Row="1" Text="Foregound:"
                           VerticalAlignment="Center" />
                <ColorPicker Grid.Column="1" Grid.Row="1" Color="{Binding ForegroundColor}" />
                
                <TextBlock Grid.Row="2" Text="Background:"
                           VerticalAlignment="Center" />
                <ColorPicker Grid.Column="1" Grid.Row="2" Color="{Binding BackgroundColor}" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2"
                  Header="Result">
            <Image Source="{Binding QrCodeImage}" 
                   RenderOptions.BitmapInterpolationMode="None"/>
        </GroupBox>
    </Grid>
</UserControl>