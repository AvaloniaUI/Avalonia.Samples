    <Application.Styles>
        <FluentTheme />

        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />

        <Style Selector="TextBlock.h1">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
        </Style>

        <Style Selector="ColorPicker">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Width" Value="200" />
            <Setter Property="IsAlphaEnabled" Value="False" />
            <Setter Property="Content" Value="{Binding $self.Color}" />
            <Setter Property="ContentTemplate">
                <DataTemplate DataType="Color">
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="5">
                        <Border CornerRadius="5"
                                Background="{Binding Converter={x:Static conv:BrushConverter.ColorToSolidColorBrushConverter}}"
                                Margin="3"
                                BorderBrush="{DynamicResource TextBoxBorderThemeBrush}"
                                Width="{Binding $self.Bounds.Height}"/>
                        <TextBlock Grid.Column="1" Text="{Binding}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </Setter>

            <Style Selector="^ /template/ DropDownButton">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>
        </Style>
    </Application.Styles>
</Application>